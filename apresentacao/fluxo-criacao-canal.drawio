<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-04-13" agent="Kiro" version="24.0.0" type="device">
  <diagram id="channel-creation" name="Criação Orquestrada de Canal">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- TÍTULO -->
        <mxCell id="title" value="Fluxo de Criação Orquestrada de Canal (4 Etapas + Rollback)" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="700" height="40" as="geometry"/>
        </mxCell>

        <!-- USUÁRIO -->
        <mxCell id="user" value="Operador NOC&#xa;&quot;Criar canal X&quot;" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.user;labelBackgroundColor=none;sketch=0;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="50" height="50" as="geometry"/>
        </mxCell>

        <!-- BEDROCK -->
        <mxCell id="bedrock" value="Bedrock Agent&#xa;(Coleta parâmetros&#xa;conversacionalmente)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="220" y="75" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- LAMBDA CONFIGURADORA -->
        <mxCell id="lambda-conf" value="Lambda Configuradora" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="520" y="75" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- ETAPA 1 -->
        <mxCell id="step1" value="Etapa 1&#xa;Criar Canal&#xa;MediaPackage V2&#xa;(Channel Group + Channel)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontStyle=0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="520" y="190" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- ETAPA 2 -->
        <mxCell id="step2" value="Etapa 2&#xa;Criar Endpoints&#xa;HLS / DASH&#xa;no MediaPackage V2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontStyle=0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="520" y="310" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- ETAPA 3 -->
        <mxCell id="step3" value="Etapa 3&#xa;Criar Inputs&#xa;MediaLive&#xa;(RTMP/RTP + Failover)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontStyle=0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="520" y="430" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- ETAPA 4 -->
        <mxCell id="step4" value="Etapa 4&#xa;Criar Canal&#xa;MediaLive&#xa;(vincula inputs + endpoints)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontStyle=0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="520" y="550" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- SUCESSO -->
        <mxCell id="success" value="✅ Canal Criado&#xa;com Sucesso!" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="520" y="680" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- DECISÃO FALHA -->
        <mxCell id="fail-check" value="Falha?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="790" y="370" width="80" height="80" as="geometry"/>
        </mxCell>

        <!-- ROLLBACK -->
        <mxCell id="rollback" value="🔄 ROLLBACK&#xa;AUTOMÁTICO&#xa;&#xa;Desfaz todas as&#xa;etapas anteriores&#xa;em ordem reversa" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="940" y="330" width="180" height="120" as="geometry"/>
        </mxCell>

        <!-- AUDIT -->
        <mxCell id="audit" value="📋 S3_Audit&#xa;Registro de&#xa;todas as operações" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontStyle=0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="940" y="190" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- SETAS -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;" edge="1" source="user" target="bedrock" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;" edge="1" source="bedrock" target="lambda-conf" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#1565C0;" edge="1" source="lambda-conf" target="step1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#1565C0;" edge="1" source="step1" target="step2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#1565C0;" edge="1" source="step2" target="step3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#1565C0;" edge="1" source="step3" target="step4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#2E7D32;" edge="1" source="step4" target="success" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Setas para falha -->
        <mxCell id="e8" value="qualquer etapa" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;strokeColor=#F57F17;dashed=1;fontSize=9;" edge="1" source="step2" target="fail-check" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e9" value="sim" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#C62828;fontSize=10;fontStyle=1;" edge="1" source="fail-check" target="rollback" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Audit -->
        <mxCell id="e10" value="log" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1;strokeColor=#7B1FA2;dashed=1;fontSize=9;" edge="1" source="lambda-conf" target="audit" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Parâmetros coletados -->
        <mxCell id="params" value="Parâmetros coletados:&#xa;• Nome do canal&#xa;• Codec (H.264/H.265)&#xa;• Resolução (1080p/720p)&#xa;• Bitrate&#xa;• Tipo de input (RTMP/RTP)&#xa;• Failover (sim/não)" style="text;html=1;fontSize=10;align=left;verticalAlign=top;fillColor=#ECEFF1;strokeColor=#90A4AE;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="190" width="180" height="130" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>